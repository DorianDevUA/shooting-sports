          <h2 class="page-details__title">Competition Information</h2>
        </header>

        <ul class="page-details__list">
          <li class="page-details__field">
            <span class="page-details__label">Type:</span>
            <span class="page-details__value">World Championship</span>
          </li>
          <li class="page-details__field">
            <span class="page-details__label">Level:</span>
            <span class="page-details__value">International</span>
          </li>
          <li class="page-details__field">
            <span class="page-details__label">Categoty:</span>
            <span class="page-details__value">Junior</span>
          </li>
          <li class="page-details__field">
            <span class="page-details__label">Disciplines:</span>
            <span class="page-details__value">Rifle / Pistol / Shotgun</span>
          </li>
          <li class="page-details__field">
            <span class="page-details__label">Participation:</span>
            <span class="page-details__value">Individual / Mixed</span>
          </li>

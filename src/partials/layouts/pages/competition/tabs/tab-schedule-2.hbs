<section class="competition-schedule">
  <div class="competition-schedule__header">
    <h2 class="competition-schedule__title">Schedule</h2>

    <div class="competition-schedule__filters">
      <button class="competition-schedule__filter is-active" type="button">
        All Events
      </button>

      <button class="competition-schedule__filter" type="button">Rifle</button>

      <button class="competition-schedule__filter" type="button">Pistol</button>

      <button class="competition-schedule__filter" type="button">
        Shotgun
      </button>
    </div>
  </div>

  <ul class="competition-schedule__days">
    <!-- 16 JUN -->
    <li class="schedule-day">
      <header class="schedule-day__header">
        <h3 class="schedule-day__date">16 Jun 2026</h3>

        <span class="schedule-day__weekday"> Tuesday </span>
      </header>

      <ul class="schedule-day__entries">
        <li class="schedule-entry">
          <div class="schedule-entry__time">&nbsp;</div>
          <!-- <div class="schedule-entry__time">All day</div> -->

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">Arrival of Delegations</h4>
          </div>
        </li>

        <li class="schedule-entry">
          <div class="schedule-entry__time">09:00 – 16:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">Equipment Control</h4>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--control">
            Control
          </span>
        </li>

        <li class="schedule-entry">
          <div class="schedule-entry__time">09:00 – 16:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">
              Unofficial Training All Ranges
            </h4>

            <div class="schedule-entry__meta">
              <span class="schedule-entry__stage">Unofficial Training </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__range"> All Ranges </span>
            </div>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--training">
            Training
          </span>
        </li>
      </ul>
    </li>

    <!-- 17 JUN -->
    <li class="schedule-day">
      <header class="schedule-day__header">
        <h3 class="schedule-day__date">17 Jun 2026</h3>

        <span class="schedule-day__weekday"> Wednesday </span>
      </header>

      <div class="schedule-day__entries">
        <article class="schedule-entry">
          <div class="schedule-entry__time">08:00 – 16:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">Equipment Control</h4>
          </div>
          <span class="schedule-entry__badge schedule-entry__badge--control">
            Control
          </span>
        </article>

        <article class="schedule-entry">
          <div class="schedule-entry__time">09:00 – 10:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">10m Air Pistol Women Junior</h4>

            <div class="schedule-entry__meta">
              <span class="schedule-entry__stage"> Pre-event Training </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__relay"> Relay 1 </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__range"> Range A </span>
            </div>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--training">
            Training
          </span>
        </article>

        <article class="schedule-entry">
          <div class="schedule-entry__time">16:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">
              Technical Meeting Rifle / Pistol / Skeet
            </h4>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--meeting">
            Meeting
          </span>
        </article>
      </div>
    </li>

    <!-- 18 JUN -->
    <li class="schedule-day">
      <header class="schedule-day__header">
        <h3 class="schedule-day__date">18 Jun 2026</h3>

        <span class="schedule-day__weekday"> Thursday </span>
      </header>

      <div class="schedule-day__entries">
        <article class="schedule-entry">
          <div class="schedule-entry__time">09:15 – 10:30</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">10m Air Pistol Women Junior</h4>

            <div class="schedule-entry__meta">
              <span class="schedule-entry__stage"> Qualification </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__range"> Relay 1 </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__range"> Range A </span>
            </div>
          </div>
          <span
            class="schedule-entry__badge schedule-entry__badge--competition"
          >
            Competition
          </span>
        </article>

        <article class="schedule-entry">
          <div class="schedule-entry__time">14:00</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">10m Air Pistol Women Junior</h4>

            <div class="schedule-entry__meta">
              <span class="schedule-entry__stage"> Final </span>
              <span class="schedule-entry__separator"></span>
              <span class="schedule-entry__range"> Finals Hall </span>
            </div>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--final">
            Final
          </span>
        </article>

        <article class="schedule-entry">
          <div class="schedule-entry__time">14:45</div>

          <div class="schedule-entry__body">
            <h4 class="schedule-entry__title">Medal Ceremony APWJ</h4>
          </div>

          <span class="schedule-entry__badge schedule-entry__badge--medal">
            Medal
          </span>
        </article>
      </div>
    </li>
  </ul>
</section>

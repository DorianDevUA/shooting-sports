{{!-- Tab Panel Schedule --}}
<section class="competition-schedule">
  <div class="competition-schedule__header">
    <h2 class="competition-schedule__title">Schedule</h2>

    <div class="competition-schedule__controls">
      <button class="competition-schedule__filter is-active">All Events</button>

      <button class="competition-schedule__filter">Rifle</button>

      <button class="competition-schedule__filter">Pistol</button>

      <button class="competition-schedule__filter">Shotgun</button>
    </div>
  </div>

  <div class="competition-schedule__days">
    <!-- Day -->

    <section class="schedule-day">
      <header class="schedule-day__header">
        <h3 class="schedule-day__date">24 May 2026</h3>

        <span class="schedule-day__weekday"> Sunday </span>
      </header>

      <div class="schedule-day__events">
        <article class="schedule-event">
          <div class="schedule-event__time">09:00</div>

          <div class="schedule-event__content">
            <h4 class="schedule-event__title">10m Air Rifle Men</h4>

            <div class="schedule-event__meta">
              <span class="schedule-event__stage"> Qualification </span>

              <span class="schedule-event__separator"></span>

              <span class="schedule-event__range"> Range A </span>
            </div>
          </div>

          <div class="schedule-event__status">Upcoming</div>
        </article>

        <article class="schedule-event">
          <div class="schedule-event__time">14:30</div>

          <div class="schedule-event__content">
            <h4 class="schedule-event__title">10m Air Pistol Women</h4>

            <div class="schedule-event__meta">
              <span class="schedule-event__stage"> Final </span>

              <span class="schedule-event__separator"></span>

              <span class="schedule-event__range"> Finals Hall </span>
            </div>
          </div>

          <div class="schedule-event__status schedule-event__status--live">
            Live
          </div>
        </article>
      </div>
    </section>

    <!-- Day -->

    <article class="schedule-day">
      <header class="schedule-day__header">
        <h3 class="schedule-day__date">25 May 2026</h3>

        <span class="schedule-day__weekday"> Monday </span>
      </header>

      <div class="schedule-day__events">
        <article class="schedule-event">
          <div class="schedule-event__time">10:00</div>

          <div class="schedule-event__content">
            <h4 class="schedule-event__title">50m Rifle 3 Positions Men</h4>

            <div class="schedule-event__meta">
              <span class="schedule-event__stage"> Qualification </span>

              <span class="schedule-event__separator"></span>

              <span class="schedule-event__range"> Range B </span>
            </div>
          </div>

          <div class="schedule-event__status">Upcoming</div>
        </article>
      </div>
    </article>
  </div>
</section>

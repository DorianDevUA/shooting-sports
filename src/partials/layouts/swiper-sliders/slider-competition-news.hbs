{{!-- Competition News Slider --}}
<section class="section" data-news="competitions">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="section__title">Competitions News</h2>
      <!-- Section Link -->
      <a class="section__link" href="news/competitions/">
        <span class="text">View all</span>
        <span class="u-sr-only">&nbsp;competitions news</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      The Pistol Team represents Azerbaijan in precision shooting disciplines.
      Athletes demonstrate accuracy, control, and consistent performance in
      international competitions.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Competition News Slider (main container) -->
      <div class="slider-competition-news swiper">
        <!-- Slider Wrapper -->
        <div
          class="slider-competition-news__wrapper js-slider-competition-news"
        >
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper js-list-competition-news">
            <!-- Swiper Slides -->
          </ul>

          <!-- Slider Pagination -->
          <div class="swiper-pagination js-pagination-competition-news"></div>

          <!-- Slider Navigation -->
          <div class="slider-competition-news__navigation">
            <!-- Prev Slide Button -->
            <button class="swiper-button-prev js-prev-competition-news">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-left"></use>
              </svg>
            </button>
            <!-- Next Slide Button -->
            <button class="swiper-button-next js-next-competition-news">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-right"></use>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

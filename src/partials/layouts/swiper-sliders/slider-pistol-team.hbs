{{!-- Pistol Team Slider --}}
<section class="section pistol">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="title">Pistol Team</h2>
      <!-- Section Link -->
      <a class="section__link" href="athletes/?discipline=pistol">
        <span class="text">See all</span>
        <span class="u-sr-only">&nbsp;athletes of the Pistol team</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      The Pistol Team represents Azerbaijan in precision shooting disciplines.
      Athletes demonstrate accuracy, control, and consistent performance in
      international competitions.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Pistol Team Slider (main container) -->
      <div class="slider-pistol-team swiper">
        <!-- Slider Wrapper -->
        <div class="slider-pistol-team__wrapper js-slider-pistol-team">
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper js-list-pistol-team">
            <!-- Swiper Slides -->
          </ul>

          <!-- Slider Pagination -->
          <!-- <div class="swiper-pagination js-pagination-pistol-team"></div> -->

          <!-- Slider Navigation -->
          <div class="slider-pistol-team__navigation">
            <!-- Prev Slide Button -->
            <button
              type="button"
              class="swiper-button-prev js-next-pistol-team"
            >
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-left"></use>
              </svg>
            </button>

            <!-- Prev Slide Button -->
            <button
              type="button"
              class="swiper-button-next js-next-pistol-team"
            >
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-right"></use>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

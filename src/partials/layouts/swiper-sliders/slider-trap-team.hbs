{{!-- Trap Team --}}
<section class="section trap">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="title">Trap Team</h2>
      <!-- Section Link -->
      <a class="section__link" href="athletes/?discipline=trap">
        <span class="text">See all</span>
        <span class="u-sr-only">&nbsp;athletes of the TRAP team</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      The Trap Team competes in one of the most demanding shooting disciplines.
      Athletes show precision and consistency in international competitions.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Trap Team Slider (main container) -->
      <div class="slider-trap-team swiper">
        <!-- Slider Wrapper -->
        <div class="slider-trap-team__wrapper js-slider-trap-team">
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper js-list-trap-team">
            <!-- Swiper Slides -->
          </ul>

          <!-- Slider Pagination -->
          <!-- <div class="swiper-pagination js-pagination-trap-team"></div> -->

          <!-- Slider Navigation buttons -->
          <div class="slider-trap-team__navigation">
            <!-- Prev Slide Button -->
            <button type="button" class="swiper-button-prev js-prev-trap-team">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-left"></use>
              </svg>
            </button>

            <!-- Next Slide Button -->
            <button type="button" class="swiper-button-next js-next-trap-team">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-right"></use>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

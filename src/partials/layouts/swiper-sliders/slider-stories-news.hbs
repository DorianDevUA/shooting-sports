{{!-- Interviews & Stories Slider --}}
<section class="section" data-news="competitions">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="section__title">Interviews & Stories</h2>
      <!-- Section Link -->
      <a class="section__link" href="news/competitions/">
        <span class="text">View all</span>
        <span class="u-sr-only">&nbsp;Interviews and Stories</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      The Pistol Team represents Azerbaijan in precision shooting disciplines.
      Athletes demonstrate accuracy, control, and consistent performance in
      international competitions.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Stories News Slider (main container) -->
      <div class="slider-stories-news swiper">
        <!-- Slider Wrapper -->
        <div class="slider-stories-news__wrapper js-slider-stories-news">
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper js-list-stories-news">
            <!-- Swiper Slides -->
            <li class="swiper-slide">
              <article class="story-card">
                <img
                  class="story-card__image"
                  src="assets/images/news/interviews/cover-02.jpg"
                  alt=""
                />

                <div class="story-card__overlay">
                  <span class="story-card__category">Interview</span>

                  <h3 class="story-card__title">
                    National Team Captain Talks About Olympic Goals
                  </h3>
                </div>
              </article>
            </li>

            <li class="swiper-slide">
              <article class="story-card">
                <img
                  class="story-card__image"
                  src="assets/images/news/interviews/cover-01.jpg"
                  alt=""
                />

                <div class="story-card__overlay">
                  <span class="story-card__category">Behind The Scenes</span>

                  <h3 class="story-card__title">
                    Training Day Inside Azerbaijan Shooting Center
                  </h3>
                </div>
              </article>
            </li>
          </ul>

          <!-- Swiper Pagination -->
          <div class="swiper-pagination js-pagination-stories-news"></div>

          <!-- Swiper Navigation buttons -->
          <div class="slider-stories-news__navigation">
            <button class="swiper-button-prev js-prev-stories-news">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-left"></use>
              </svg>
            </button>
            <button class="swiper-button-next js-next-stories-news">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-right"></use>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

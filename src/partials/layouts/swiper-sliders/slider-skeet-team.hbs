{{!-- Skeet Team --}}
<section class="section skeet">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="title">Skeet Team</h2>
      <!-- Section Link -->
      <a class="section__link" href="athletes/?discipline=skeet">
        <span class="text">See all</span>
        <span class="u-sr-only">&nbsp;athletes of the Skeet team</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      The Skeet Team participates in dynamic clay target disciplines. Athletes
      demonstrate strong coordination and compete at international level.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Skeet Team Slider (main container) -->
      <div class="slider-skeet-team swiper">
        <!-- Slider Wrapper -->
        <div class="slider-skeet-team__wrapper js-slider-skeet-team">
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper js-list-skeet-team">
            <!-- Swiper Slides -->
          </ul>

          <!-- Slider Pagination -->
          <!-- <div class="swiper-pagination js-pagination-skeet-team"></div> -->

          <!-- Slider Navigation -->
          <div class="slider-skeet-team__navigation">
            <!-- Prev Slide Button -->
            <button type="button" class="swiper-button-prev js-prev-skeet-team">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-left"></use>
              </svg>
            </button>

            <!-- Next Slide Button -->
            <button type="button" class="swiper-button-next js-next-skeet-team">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-chevron-right"></use>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
